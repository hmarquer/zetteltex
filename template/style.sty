\newcommand{\smoothManifold}[3]{
    \begin{tikzpicture}[scale=1.8]
        \coordinate (A) at (0.5, -0.7);
        \coordinate (B) at (1.2, 0.);
        \coordinate (C) at (-.5, 0.2);
        \coordinate (D) at (-1., -0.5);
        \draw[thick] (A) to[out=70,in=170] (B);
        \draw[thick] (B) to[out=150,in=20] (C);
        \draw[thick] (C) to[out=210,in=80] (D);
        \draw[thick] (D) to[out=20,in=130] (A);
        \draw[fill=black] (0,0) circle (0.6pt) node[anchor=north west]{#3};
        \draw[dashed] plot[smooth cycle,tension=0.8] coordinates {(-0.2,-0.25) (-0.35,0.1) (0.3,0.2) (0.3,-0.25)};
        \node[anchor=north] at (-0.6, 0.) {#2};
        \node[anchor=north] at (0.9, -0.25) {#1};
    \end{tikzpicture}
}

\newcommand{\smoothCoords}[3]{
    \begin{tikzpicture}[scale=1.4]
        \draw[->,thick] (0, -.4) -- (0, 1.5);
        \draw[->,thick] (-.4, 0) -- (1.5, 0);
        \draw[dashed] plot[smooth cycle,tension=0.8] coordinates {(0.4,0.3) (0.35,1.1) (1.,1.) (1.5,0.3)};
        \draw[fill=black] (0.65,0.7) circle (0.6pt) node[anchor=north west]{#3}; 
        \node at (0.75, -.3) {#1};
        \node at (1.2, 1.25) {#2};
    \end{tikzpicture}
}

