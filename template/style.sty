% Comando auxiliar: inicializa un entorno de teorema
% #1 = nombre del entorno interior, #2 = argumento opcional del entorno
\newcommand{\@thmenvinit}[2]{%
    \ifx\relax#2\relax
        \begin{#1}%
    \else
        \begin{#1}[#2]%
    \fi
    \let\oldlabel\label
    \renewcommand{\label}[1]{\oldlabel{##1}\@bsphack\@esphack\unskip\ignorespaces}%
    % \leavevmode
    % \hangindent=\margenizq \hangafter=1
    % \everypar{\hangindent=0cm\setlength{\leftskip}{\margenizq}\global\everypar{}}%
}

% Fábrica de entornos de teorema
% #1 = nombre corto, #2 = nombre del entorno interior, #3 = código previo (p.ej. \setlist) o vacío
\newcommand{\NewThmEnv}[3]{%
    \newenvironment{#1}[1][]{%
        #3%
        \@thmenvinit{#2}{##1}%
        \begin{thlist}%
            \item[] \hspace{-\labelsep}
    }{\end{thlist}\end{#2}}%
}

